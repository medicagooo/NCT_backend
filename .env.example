# Copy to `.dev.vars` before running local Worker development:
# cp .env.example .dev.vars
#
# The same keys should be set in Cloudflare Variables / Secrets for remote deploys.
# They are intentionally not stored in `wrangler.toml`, so Git-based deploys
# with `wrangler deploy --keep-vars` do not overwrite Dashboard values.
# Cloudflare binding required by this Worker but not set through `.env`:
# - `DB`: D1 database binding, configured in `wrangler.toml`
#
# Runtime-generated values you do NOT need to hand-fill:
# - Form protection secret: generated on first use and cached in D1 system records
#
# `NO_TORSION_SITE_URL` is intentionally omitted because the current runtime no
# longer reads it. The runtime also no longer reads
# `NO_TORSION_GOOGLE_FORM_URL` / `NO_TORSION_CORRECTION_GOOGLE_FORM_URL`; only
# the `*_FORM_ID` keys below are used.
#
# Tables below are sorted by importance.
# `Default` means the runtime behavior when the variable is omitted.

# Priority 1 - Required for mother/sub linkage
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `SERVICE_PUBLIC_URL` | none | Public origin this sub reports to the mother and uses as the shared HMAC seed for mother/sub requests. |
# | `MOTHER_REPORT_URL` | none | Mother service base URL; `/api/sub/report` and `/api/sub/form-records` are appended by the Worker. |
# Production routes baked into wrangler.toml are testdb.medicago.top (mother) and
# testbk.medicago.top (sub); update both URLs together if those domains change.
SERVICE_PUBLIC_URL=https://testbk.medicago.top
MOTHER_REPORT_URL=https://testdb.medicago.top

# Priority 2 - Review for No-Torsion production behavior
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `NO_TORSION_FORM_DRY_RUN` | `true` | When `true`, form submissions stay in preview/confirm mode instead of sending to Google Form automatically. |
# | `NO_TORSION_FORM_SUBMIT_TARGET` | `both` | Controls whether confirmed form submissions write to Google, D1, or both. |
# | `NO_TORSION_CORRECTION_SUBMIT_TARGET` | `both` | Controls whether correction submissions write to Google, D1, or both. |
# | `NO_TORSION_MEDIA_SUBMIT_TARGET` | `both` | `b2` uploads only to Backblaze B2 and skips the D1 row; `d1` writes the metadata row only and skips B2; `both` performs both (default). |
NO_TORSION_FORM_DRY_RUN=true
NO_TORSION_FORM_SUBMIT_TARGET=both
NO_TORSION_CORRECTION_SUBMIT_TARGET=both
NO_TORSION_MEDIA_SUBMIT_TARGET=both

# Priority 3 - Optional external integrations
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `NO_TORSION_FORM_ID` | blank -> built-in default form ID | Google Form ID for main submissions. |
# | `NO_TORSION_CORRECTION_FORM_ID` | blank -> built-in default correction form ID | Google Form ID for correction submissions. |
# | `GOOGLE_CLOUD_TRANSLATION_API_KEY` | blank | Enables `/api/no-torsion/translate-text`; blank makes translation requests return a configuration error. |
NO_TORSION_FORM_ID=
NO_TORSION_CORRECTION_FORM_ID=
GOOGLE_CLOUD_TRANSLATION_API_KEY=

# Priority 4 - B2 media upload
# Bucket name, S3 endpoint, and public base URL are hard-coded in
# `src/lib/media.ts` (`jiaozheng` bucket on `eu-central-003`); only the
# credential pair below needs to be supplied.
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `B2_APPLICATION_KEY_ID` | none | Backblaze B2 application key id used for S3-compatible presigned uploads. Set as a Cloudflare/GitHub secret; do not commit real values. |
# | `B2_APPLICATION_KEY` | none | Backblaze B2 application key secret. Set as a Cloudflare/GitHub secret; do not commit real values. |
# | `B2_ALLOWED_MIME_TYPES` | image/video defaults | Comma-separated allowed MIME types. |
# | `B2_UPLOAD_MAX_BYTES` | `104857600` | Maximum single media upload size. |
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_ALLOWED_MIME_TYPES=image/gif,image/jpeg,image/png,image/webp,video/mp4,video/webm
B2_UPLOAD_MAX_BYTES=104857600

# Priority 5 - Optional naming and tuning
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `APP_NAME` | `NCT API SQL Sub` | Human-readable service name used in health and mother report payloads. |
# | `MOTHER_REPORT_TIMEOUT_MS` | `10000` | Timeout for periodic report requests sent to the mother. |
# | `MOTHER_FORM_SYNC_BATCH_SIZE` | `20` | Maximum number of pending D1 form/correction rows sent to the mother in one batch. |
# | `MOTHER_FORM_SYNC_TIMEOUT_MS` | `MOTHER_REPORT_TIMEOUT_MS` -> `10000` | Timeout for each `sub -> mother` form/correction sync request. |
# | `DATABACK_EXPORT_MIN_INTERVAL_MS` | `60000` | Minimum interval between public `GET /api/export/nct_databack` requests. |
# | `DEBUG_MOD` | `false` | Enables `/debug` standalone page previews when set to `true`; keep disabled outside temporary testing. |
# | `NO_TORSION_FORM_PROTECTION_MIN_FILL_MS` | `3000` | Minimum allowed client fill time before a form token is accepted. |
# | `NO_TORSION_FORM_PROTECTION_MAX_AGE_MS` | `86400000` | Maximum age of a form protection token before it expires. |
# | `TRANSLATION_PROVIDER_TIMEOUT_MS` | `10000` | Timeout for each Google Cloud Translation request. |
APP_NAME="NCT API SQL Sub"
MOTHER_REPORT_TIMEOUT_MS=10000
MOTHER_FORM_SYNC_BATCH_SIZE=20
MOTHER_FORM_SYNC_TIMEOUT_MS=10000
DATABACK_EXPORT_MIN_INTERVAL_MS=60000
DEBUG_MOD=false
NO_TORSION_FORM_PROTECTION_MIN_FILL_MS=3000
NO_TORSION_FORM_PROTECTION_MAX_AGE_MS=86400000
TRANSLATION_PROVIDER_TIMEOUT_MS=10000
